# Public env vars — Astro exposes anything with PUBLIC_ prefix to the client bundle.

# PostHog analytics — optional. Absent = no init, no events, no network calls.
# Production: set as a GitHub Actions repo secret (the site deploys to GH Pages
# via .github/workflows/deploy.yml; secrets are baked into the build there).
#   gh secret set PUBLIC_POSTHOG_KEY --body "phc_..."
# Key lives at posthog.com → Project Settings → Project API Key.
PUBLIC_POSTHOG_KEY=
# Defaults to https://us.i.posthog.com; override for EU instance or self-host.
# PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
